# i3blocks config
#
# Each block command defaults to $SCRIPT_DIR/$BLOCK_NAME/$BLOCK_NAME.
# SCRIPT_DIR is set by the bar command in the i3 config:
#   status_command SCRIPT_DIR=~/.config/i3blocks/scripts i3blocks -c ~/.config/i3blocks/config

command=$SCRIPT_DIR/$BLOCK_NAME/$BLOCK_NAME
separator_block_width=15
markup=none


# --- System info hint (click or mod+i to show notification) ---

[sysinfo-hint]
command=$HOME/.config/i3/scripts/sysinfo_block.sh
markup=pango
interval=once
color=#928374


# --- Clock ---

[time]
label=
command=date '+%H:%M'
color=#EBDBB2
interval=60


# --- Audio ---

[volume-pipewire]
command=$HOME/.config/i3/scripts/volume_status.sh
markup=pango
interval=persist
color=#B8BB26


# --- Power (hidden gracefully when no battery present) ---

[battery2]
markup=pango
interval=30


