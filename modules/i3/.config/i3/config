bindsym $mod+Ctrl+4 exec --no-startup-id $HOME/Main/Additional_Config/Scripts/i3_move_to_workspace.sh 4
bindsym $mod+Ctrl+5 exec --no-startup-id $HOME/Main/Additional_Config/Scripts/i3_move_to_workspace.sh 5
bindsym $mod+Ctrl+6 exec --no-startup-id $HOME/Main/Additional_Config/Scripts/i3_move_to_workspace.sh 6
