# i3blocks config
#
# Each block command defaults to $SCRIPT_DIR/$BLOCK_NAME/$BLOCK_NAME.
# SCRIPT_DIR is set by the bar command in the i3 config:
#   status_command SCRIPT_DIR=~/Main/Additional_Config/i3blocks_Scripts i3blocks -c ~/.config/i3blocks/config

command=$SCRIPT_DIR/$BLOCK_NAME/$BLOCK_NAME
separator_block_width=15
markup=none


# --- System info (click to show notification) ---

[sysinfo]
color=#928374
interval=once


# --- Audio ---

[volume]
label=Volume
color=#B8BB26
interval=once
signal=10


# --- Power (hidden gracefully when no battery present) ---

[battery2]
markup=pango
interval=30


# --- Network (uncomment if needed) ---

# [iface]
# color=#8EC07C
# interval=10
# separator=false
# separator_block_width=5

# [wifi]
# label=WiFi
# color=#8EC07C
# interval=10


# --- Clock ---

[time]
label=
command=date '+%H:%M'
color=#EBDBB2
interval=60
