# Haven't used this in a while so can probably remove it. Though I won't just yet
"xcalib -i -a"
    Control+Alt+i

"amixer set Master toggle"
    Control+Alt+m

"~/Main/Additional_Config/Temporary_Scripts/current_temporary_script.sh"
    Control+F5

"~/Main/Additional_Config/Temporary_Scripts/second_current_temporary_script.sh"
    Control+F6

"xdotool click 4"
  Alt + k

"xdotool click 5"
  Alt + j
